        "/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Autentica um usuário e retorna o token Sanctum",
                "operationId": "2dd578ff7aba2721293dac66833b27d1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "joao@techsolutions.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "SenhaForte123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login efetuado com sucesso."
                    },
                    "401": {
                        "description": "Credenciais inválidas."
                    }
                }
            }
        },
        "/compras": {
            "get": {
                "tags": [
                    "Compras"
                ],
                "summary": "Lista (paginada) as compras do tenant (títulos a pagar)",
                "operationId": "95385498bacd9113ea8b47fdd62f1903",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "PENDENTE",
                                "PAGO",
                                "ATRASADO",
                                "CANCELADO"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de compras."
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Compras"
                ],
                "summary": "Registra uma compra (atualiza estoque, financeiro e contabilidade)",
                "operationId": "ff378324319eb1b1ed647d91e412d347",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "supplier_id",
                                    "produto_id",
                                    "quantidade",
                                    "custo_unitario",
                                    "forma_pagamento",
                                    "data_compra"
                                ],
                                "properties": {
                                    "supplier_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "produto_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "quantidade": {
                                        "type": "number",
                                        "example": 10
                                    },
                                    "custo_unitario": {
                                        "type": "number",
                                        "example": 5.5
                                    },
                                    "forma_pagamento": {
                                        "type": "string",
                                        "example": "PRAZO"
                                    },
                                    "data_compra": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-07-01"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Compra criada."
                    },
                    "422": {
                        "description": "Erro de validação."
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
