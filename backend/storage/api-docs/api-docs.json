        "/lancamentos": {
            "post": {
                "tags": [
                    "Lançamentos"
                ],
                "summary": "Registra um lançamento contábil manual (partidas dobradas)",
                "operationId": "c9ed0dc10ad1834ad781e8265adef7a7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "description",
                                    "date",
                                    "partidas"
                                ],
                                "properties": {
                                    "description": {
                                        "type": "string",
                                        "example": "Integralização de capital"
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-07-01"
                                    },
                                    "partidas": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "conta_id",
                                                "valor",
                                                "natureza"
                                            ],
                                            "properties": {
                                                "conta_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "valor": {
                                                    "type": "number",
                                                    "example": 1000
                                                },
                                                "natureza": {
                                                    "type": "string",
                                                    "example": "D"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Lançamento criado."
                    },
                    "422": {
                        "description": "Débitos e créditos não batem / erro de validação."
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
